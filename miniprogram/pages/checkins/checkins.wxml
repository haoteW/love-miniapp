<view class="page">
  <view class="list-header">
    <view>
      <view class="title">约会打卡</view>
      <view class="subtitle">每一次出发都有痕迹</view>
    </view>
    <button class="ghost-button add-button" bindtap="add">打卡</button>
  </view>

  <view wx:for="{{items}}" wx:key="id" class="card checkin-card">
    <view class="item-title">{{item.title}}</view>
    <view class="subtitle">{{item.date}} · {{item.locationName}}</view>
    <view wx:if="{{item.images && item.images.length}}" class="image-grid">
      <image
        wx:for="{{item.images}}"
        wx:for-item="image"
        wx:key="*this"
        class="image-thumb"
        src="{{image}}"
        mode="aspectFill"
        data-current="{{image}}"
        data-images="{{item.images}}"
        bindtap="previewImage"
      />
    </view>
  </view>
</view>
