.home-page {
  padding-top: 48rpx;
}

.hero {
  padding: 48rpx 32rpx;
  border-radius: 28rpx;
  background: linear-gradient(145deg, #f47c9d, #ffb1c4);
  color: #ffffff;
  text-align: center;
}

.hero .subtitle {
  color: rgba(255, 255, 255, 0.88);
}

.days {
  margin: 18rpx 0;
  font-size: 112rpx;
  font-weight: 800;
  line-height: 1;
}

.hero-button {
  margin-top: 36rpx;
  background: #ffffff;
  color: #f47c9d;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-top: 28rpx;
}

.quick-item {
  padding: 34rpx 20rpx;
  border-radius: 16rpx;
  background: #ffffff;
  color: #513943;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
}

.calendar-card {
  padding-bottom: 24rpx;
}

.calendar-header {
  margin-bottom: 24rpx;
}

.calendar-title-row {
  display: grid;
  align-items: center;
  grid-template-columns: 72rpx 1fr 72rpx;
  gap: 8rpx;
}

.calendar-month-title {
  overflow: hidden;
  color: #513943;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 56rpx;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.calendar-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  margin: 0 auto;
  border-radius: 28rpx;
  background: #fff0f4;
  color: #f47c9d;
  font-size: 40rpx;
  line-height: 1;
}

.calendar-nav:active {
  opacity: 0.72;
}

.weekday-row,
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
}

.weekday {
  height: 44rpx;
  color: #8a6f78;
  font-size: 24rpx;
  line-height: 44rpx;
  text-align: center;
}

.calendar-day {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  border-radius: 12rpx;
  color: #513943;
  font-size: 26rpx;
}

.calendar-day.has-records {
  background: #fff7f9;
}

.calendar-day.is-selected {
  background: #ffe1ea;
}

.calendar-day.has-records:active {
  opacity: 0.72;
}

.calendar-day.is-empty {
  opacity: 0;
}

.calendar-day.is-today .calendar-number {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background: #f47c9d;
  color: #ffffff;
}

.record-dots {
  position: absolute;
  bottom: 8rpx;
  left: 50%;
  display: flex;
  gap: 6rpx;
  transform: translateX(-50%);
}

.record-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 4rpx;
}

.record-dot.female {
  background: #f47c9d;
}

.record-dot.male {
  background: #4a90e2;
}

.calendar-records {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #fff0f4;
}

.calendar-records-title {
  color: #513943;
  font-size: 26rpx;
  font-weight: 700;
}

.calendar-empty {
  margin-top: 14rpx;
  color: #8a6f78;
  font-size: 24rpx;
}

.calendar-record-item {
  display: flex;
  align-items: center;
  margin-top: 14rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  background: #fff7f9;
}

.calendar-record-item:active {
  opacity: 0.72;
}

.calendar-record-type {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 84rpx;
  height: 44rpx;
  margin-right: 16rpx;
  border-radius: 22rpx;
  background: #fff0f4;
  color: #f47c9d;
  font-size: 22rpx;
  line-height: 1;
}

.calendar-record-type.checkin {
  background: #eaf3ff;
  color: #4a90e2;
}

.calendar-record-type.wish {
  background: #edf8f1;
  color: #3a9b64;
}

.calendar-record-type.anniversary {
  background: #fff0f4;
  color: #f47c9d;
}

.calendar-record-main {
  flex: 1;
  min-width: 0;
}

.calendar-record-title {
  overflow: hidden;
  color: #513943;
  font-size: 26rpx;
  font-weight: 600;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.calendar-record-summary {
  overflow: hidden;
  margin-top: 4rpx;
  color: #8a6f78;
  font-size: 22rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}
