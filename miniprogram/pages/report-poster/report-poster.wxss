.poster-page {
  padding-top: 32rpx;
}

.poster-hero {
  padding: 44rpx 32rpx;
  border-radius: 24rpx;
  background: linear-gradient(145deg, #f47c9d, #ffc2d1);
  color: #ffffff;
}

.poster-title {
  font-size: 46rpx;
  font-weight: 800;
  line-height: 1.2;
}

.poster-subtitle {
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 26rpx;
  line-height: 1.5;
}

.empty-card {
  text-align: center;
}

.empty-title {
  color: #513943;
  font-size: 32rpx;
  font-weight: 700;
}

.empty-text {
  margin-top: 12rpx;
  color: #8a6f78;
  font-size: 26rpx;
  line-height: 1.5;
}

.poster-panel {
  margin-bottom: 32rpx;
}

.canvas-wrap {
  display: flex;
  justify-content: center;
  padding: 20rpx 0;
  border-radius: 18rpx;
  background: #fff7f9;
}

.poster-canvas {
  width: 600rpx;
  height: 1067rpx;
  border-radius: 18rpx;
  box-shadow: 0 12rpx 32rpx rgba(244, 124, 157, 0.16);
}

.poster-actions {
  display: flex;
  align-items: center;
  margin-top: 24rpx;
}

.action-button {
  flex: 1;
  min-width: 0;
  margin: 0;
  padding: 0 14rpx;
  font-size: 28rpx;
}

.action-button + .action-button {
  margin-left: 18rpx;
}

.save-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 84rpx;
  margin-top: 18rpx;
  border-radius: 42rpx;
  background: #fff0f4;
  color: #f47c9d;
  font-size: 28rpx;
  line-height: 1;
}
